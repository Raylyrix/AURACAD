<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Gui::Dialog::DlgSettingsArch</class>
 <widget class="QWidget" name="Gui::Dialog::DlgSettingsArch">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>534</width>
    <height>718</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Iauracad Export</string>
  </property>
  <layout class="QVBoxLayout">
   <property name="spacing">
    <number>6</number>
   </property>
   <property name="leftMargin">
    <number>9</number>
   </property>
   <property name="topMargin">
    <number>9</number>
   </property>
   <property name="rightMargin">
    <number>9</number>
   </property>
   <property name="bottomMargin">
    <number>9</number>
   </property>
   <item>
    <widget class="QGroupBox" name="groupBox">
     <property name="title">
      <string>Export Options</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_2">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_2">
        <item>
         <widget class="QLabel" name="label_2">
          <property name="toolTip">
           <string>The type of objects to export:
- Standard model: solid objects
- Structural analysis: wireframe model for structural calculations
- Standard + structural: both types of models</string>
          </property>
          <property name="text">
           <string>Export type</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="Gui::PreauracadomboBox" name="comboBox">
          <property name="toolTip">
           <string>The type of objects to export:
- Standard model: solid objects
- Structural analysis: wireframe model for structural calculations
- Standard + structural: both types of models</string>
          </property>
          <property name="prefEntry" stdset="0">
           <cstring>iauracadExportModel</cstring>
          </property>
          <property name="prefPath" stdset="0">
           <cstring>Mod/Arch</cstring>
          </property>
          <item>
           <property name="text">
            <string>Standard model</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Structural analysis</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Standard + structural</string>
           </property>
          </item>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox">
        <property name="toolTip">
         <string>Some Iauracad viewers do not like objects exported as extrusions.
Use this to force all objects to be exported as BREP geometry.</string>
        </property>
        <property name="text">
         <string>Force export as BREP</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadExportAsBrep</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_4">
        <property name="toolTip">
         <string>Use triangulation options set in the DAE options page</string>
        </property>
        <property name="text">
         <string>Use DAE triangulation options</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadUseDaeOptions</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_5">
        <property name="toolTip">
         <string>Curved shapes that cannot be represented as curves in Iauracad
are decomposed into flat facets.
If this is checked, an additional calculation is done to join coplanar facets.</string>
        </property>
        <property name="text">
         <string>Join coplanar facets when triangulating</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadJoinCoplanarFacets</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_9">
        <property name="toolTip">
         <string>When exporting objects without unique ID (UID), the generated UID
will be stored inside the AuraCAD object for reuse next time that object
is exported. This leads to smaller differences between file versions.</string>
        </property>
        <property name="text">
         <string>Store Iauracad unique ID in AuraCAD objects</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadStoreUid</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_10">
        <property name="toolTip">
         <string>IauracadOpenShell is a library that enables importing Iauracad files.
Its serializer functionality allows giving it an OCC shape and it will
produce adequate Iauracad geometry: NURBS, faceted, or anything else.
Note: The serializer is still an experimental feature!</string>
        </property>
        <property name="text">
         <string>Use IauracadOpenShell serializer if available</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadSerialize</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_12">
        <property name="toolTip">
         <string>2D objects will be exported as IauracadAnnotation</string>
        </property>
        <property name="text">
         <string>Export 2D objects as IauracadAnnotations</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadExport2D</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_13">
        <property name="toolTip">
         <string>All AuraCAD object properties will be stored inside the exported objects,
allowing to recreate a full parametric model on reimport.</string>
        </property>
        <property name="text">
         <string>Export full AuraCAD parametric model</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>IauracadExportAuraCADProperties</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_15">
        <property name="toolTip">
         <string>When possible, similar entities will be used only once in the file if possible.
This can reduce the file size considerably, but will make it less easily readable.</string>
        </property>
        <property name="text">
         <string>Reuse similar entities</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>iauracadCompress</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_16">
        <property name="toolTip">
         <string>When possible, Iauracad objects that are extruded rectangles will be
exported as IauracadRectangleProfileDef.
However, some other applications might have problems importing that entity.
If this is the case, it can disabled and then all profiles will be exported as IauracadArbitraryClosedProfileDef.</string>
        </property>
        <property name="text">
         <string>Disable IauracadRectangleProfileDef</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>DisableIauracadRectangleProfileDef</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_17">
        <property name="toolTip">
         <string>Some Iauracad types such as IauracadWall or IauracadBeam have special standard versions like IauracadWallStandardCase or IauracadBeamStandardCase. If this option is turned on, AuraCAD will automatically export such objects
as standard cases when the necessary conditions are met.</string>
        </property>
        <property name="text">
         <string>Auto-detect and export as standard cases when applicable</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>getStandardCase</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_19">
        <property name="toolTip">
         <string>If no site is found in the AuraCAD document, a default one will be added.
A site is not mandatory but a common practice is to have at least one in the file.</string>
        </property>
        <property name="text">
         <string>Add default site if one is not found in the document</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>IauracadAddDefaultSite</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_20">
        <property name="toolTip">
         <string>If no building storey is found in the AuraCAD document, a default one will be added.
A building storey is not mandatory but a common practice to have at least one in the file.</string>
        </property>
        <property name="text">
         <string>Add default building storey if one is not found in the document</string>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>IauracadAddDefaultStorey</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QLabel" name="label">
          <property name="toolTip">
           <string>Desired units in the exported Iauracad file.

Note that Iauracad files are ALWAYS written in metric units; imperial units
are only a conversion factor applied on top of them.
However, some BIM applications will use this factor to choose which
unit to work with when opening the file.</string>
          </property>
          <property name="text">
           <string>Iauracad file units</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="Gui::PreauracadomboBox" name="comboBox_3">
          <property name="toolTip">
           <string>Desired units in the exported Iauracad file.

Note that Iauracad files are ALWAYS written in metric units; imperial units
are only a conversion factor applied on top of them.
However, some BIM applications will use this factor to choose which
unit to work with when opening the file.</string>
          </property>
          <property name="prefEntry" stdset="0">
           <cstring>iauracadUnit</cstring>
          </property>
          <property name="prefPath" stdset="0">
           <cstring>Mod/Arch</cstring>
          </property>
          <item>
           <property name="text">
            <string>Metric</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Imperial</string>
           </property>
          </item>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QLabel" name="label_3">
        <property name="text">
         <string>Check also native-Iauracad-specific preferences under BIM -&gt; Native Iauracad</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBox_2">
     <property name="title">
      <string>Iauracad Standard Compliance</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_3">
      <item>
       <widget class="Gui::PreauracadheckBox" name="checkBox_21">
        <property name="toolTip">
         <string>If no building is found in the AuraCAD document, a default one will be added.
Warning: The Iauracad standard asks for at least one building in each file. By turning this option off, a non-standard Iauracad file will be produced.</string>
        </property>
        <property name="text">
         <string>Add default building if one is not found in the document</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>IauracadAddDefaultBuilding</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Gui::PreauracadheckableGroupBox" name="groupBox_ExportAuraCADGroups">
        <property name="toolTip">
         <string>If not checked, standard AuraCAD groups (App::DocumentObjectGroup) will not be exported as IauracadGroup or IauracadElementAssembly.\nTheir children will be re-parented to the container of the skipped group in the Iauracad structure.</string>
        </property>
        <property name="title">
         <string>Export AuraCAD groups</string>
        </property>
        <property name="checkable">
         <bool>true</bool>
        </property>
        <property name="checked">
         <bool>false</bool>
        </property>
        <property name="prefEntry" stdset="0">
         <cstring>IauracadExportStdGroups</cstring>
        </property>
        <property name="prefPath" stdset="0">
         <cstring>Mod/Arch</cstring>
        </property>
        <layout class="QVBoxLayout" name="verticalLayout_4">
         <item>
          <widget class="Gui::PreauracadheckBox" name="checkBox_2">
           <property name="toolTip">
            <string>In AuraCAD, it is possible to nest groups inside buildings or storeys. If this option is disabled, AuraCAD groups will be saved as IauracadGroups and aggregated to the building structure. Aggregating non-building elements such as IauracadGroups is however not recommended by the Iauracad standards. It is therefore also possible to export these groups as IauracadElementAssemblies, which produces an Iauracad-compliant file.</string>
           </property>
           <property name="text">
            <string>Export nested groups as assemblies</string>
           </property>
           <property name="checked">
            <bool>true</bool>
           </property>
           <property name="prefEntry" stdset="0">
            <cstring>IauracadGroupsAsAssemblies</cstring>
           </property>
           <property name="prefPath" stdset="0">
            <cstring>Mod/Arch</cstring>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation">
      <enum>Qt::Vertical</enum>
     </property>
     <property name="sizeHint" stdset="0">
      <size>
       <width>20</width>
       <height>40</height>
      </size>
     </property>
    </spacer>
   </item>
  </layout>
 </widget>
 <layoutdefault spacing="6" margin="11"/>
 <customwidgets>
  <customwidget>
   <class>Gui::PreauracadheckBox</class>
   <extends>QCheckBox</extends>
   <header>Gui/PrefWidgets.h</header>
  </customwidget>
  <customwidget>
   <class>Gui::PreauracadomboBox</class>
   <extends>QComboBox</extends>
   <header>Gui/PrefWidgets.h</header>
  </customwidget>
